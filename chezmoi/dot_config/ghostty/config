# Ghostty Configuration
# Documentation: https://ghostty.org/docs/config/reference

# --- Shell & Integration ---
# Default shell to use
command = /opt/homebrew/bin/fish
# Enable native Ghostty shell integration for fish
shell-integration = fish

# --- Theme ---
# Theme inspired by Apple's Xcode IDE (High Contrast version)
theme = Xcode Dark hc

# --- Typography ---
# Font family (Iosevka is known for its narrow design)
font-family = IosevkaTerm Nerd Font Mono
# Default text size
font-size = 14
# Increase character width by 10% to compensate for Iosevka's natural narrowness
adjust-cell-width = 10%

# --- Window & Interface ---
# Inherit the working directory for new windows, tabs, and splits
# working-directory = inherit
# Specifically ensure new tabs/splits in the same window inherit the CWD
window-inherit-working-directory = true
# Background opacity (0.95 = 95%)
background-opacity = 0.95
# Enable background blur (glass effect)
background-blur = true
# Show standard window decorations and controls
window-decoration = true

# --- Cursor & Shaders ---
# Cursor style (block is a solid square)
cursor-style = block

# --- Ghostty Cursor Shaders (https://github.com/sahaj-b/ghostty-cursor-shaders) ---
# Available shaders:
# shaders/cursor_warp.glsl (Neovide-like trail)
# shaders/cursor_sweep.glsl (Animated trail)
# shaders/cursor_tail.glsl (Kitty-like comet trail)
# shaders/ripple_cursor.glsl (Pulse effect)
# shaders/sonic_boom_cursor.glsl (Pulse effect)
# shaders/ripple_rectangle_cursor.glsl (Pulse effect)
# shaders/rectangle_boom_cursor.glsl (Pulse effect)

custom-shader = shaders/cursor_sweep.glsl

# --- macOS Specific ---
# Map Left Option key to Alt (essential for shell shortcuts)
macos-option-as-alt = left
# Use native macOS tabs in the title bar
macos-titlebar-style = tabs

# --- Performance & Rendering ---
# Slightly thicken font strokes for better readability
font-thicken = true
# Automatically copy selected text to the clipboard
copy-on-select = true
